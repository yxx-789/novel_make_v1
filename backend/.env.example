# ==================== 百度千帆平台 API 配置 ====================
# 请在部署时填写真实的 API Key，不要将此文件提交到 Git

# 千帆 API Key（必填）
QIANFAN_API_KEY=your_qianfan_api_key_here

# 千帆 API URL（可选，使用默认值即可）
QIANFAN_API_URL=https://qianfan.baidubce.com/v2/chat/completions

# 模型配置（可选）
QIANFAN_MODEL=glm-5.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Embedding 模型（可选）
EMBEDDING_MODEL=embedding-v1

# API 服务配置（可选）
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# 环境标识
ENVIRONMENT=development

# ==================== 前端配置（如需要）====================
# 后端 API 地址
API_BASE_URL=http://localhost:8000
